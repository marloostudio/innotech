# Supabase — copy to `.env.local` and fill values from:
# https://supabase.com/dashboard/project/_/settings/api
# https://supabase.com/dashboard/project/_/settings/database
#
# After setting keys, run SQL in `supabase/migrations/` (e.g. automate intake table) via Dashboard → SQL Editor.

# Public (safe to expose in the browser via NEXT_PUBLIC_*)
# Canonical site URL — set in Vercel Production to your real domain (used by sitemap, metadata).
NEXT_PUBLIC_SITE_URL=

# Google Tag Manager container ID (public, e.g. GTM-XXXXXXX). Omit locally if you do not want GTM in dev.
# NEXT_PUBLIC_GTM_ID=

NEXT_PUBLIC_SUPABASE_URL=
# Public anon JWT / publishable key (safe with RLS). Prefer this name — Vercel flags *_ANON_KEY.
NEXT_PUBLIC_SUPABASE_ANON=
# Legacy alias (optional): NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: never commit. Use the "secret" / service role key only in API routes or server actions.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres (use the pooler URI from Database settings for Vercel/serverless)
# DATABASE_URL=

# Resend — server-only (https://resend.com). Contact + Automate: confirmation to submitter + team copy below.
# RESEND_API_KEY=
# Optional: full From header (overrides domain-based default below).
# RESEND_FROM="InnoTech Systems <noreply@yourdomain.com>"
# If unset, From uses noreply@ + domain from NEXT_PUBLIC_SITE_URL (or RESEND_FROM_DOMAIN).
# RESEND_FROM_DOMAIN=innotech-sys.com
# Team inbox for contact form internal alerts (defaults to info@innotech-sys.com if unset).
# LEADS_NOTIFY_EMAIL=
# Demo request: team copy inbox (same default: info@innotech-sys.com).
# DEMO_REQUEST_NOTIFY_EMAIL=
# Optional: Resend test mode only allows mail to your verified address — use this for the *visitor confirmation* only.
# If the team send to DEMO_REQUEST_NOTIFY_EMAIL fails, a backup copy is sent here when this is set.
# RESEND_SANDBOX_INBOX=you@verified-resend-address.com
